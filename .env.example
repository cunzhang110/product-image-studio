VITE_YUNWU_API_KEY=your_yunwu_api_key
VITE_YUNWU_BASE_URL=https://yunwu.ai
VITE_YUNWU_IMAGE_MODEL=gemini-3.1-flash-image-preview
VITE_YUNWU_TEXT_MODEL=gemini-3-pro-preview
VITE_YUNWU_ENABLE_PROMPT_REWRITE=true
VITE_YUNWU_MIN_REQUEST_INTERVAL_MS=15000
VITE_YUNWU_MAX_RATE_LIMIT_RETRIES=6
VITE_YUNWU_RATE_LIMIT_COOLDOWN_MS=60000

VITE_APIMART_API_KEY=your_apimart_api_key
VITE_APIMART_BASE_URL=https://api.apimart.ai
VITE_APIMART_IMAGE_MODEL=gpt-image-2
VITE_APIMART_TEXT_MODEL=gemini-2.5-pro
VITE_APIMART_ENABLE_PROMPT_REWRITE=true
VITE_APIMART_MIN_REQUEST_INTERVAL_MS=5000
VITE_APIMART_MAX_RATE_LIMIT_RETRIES=4
VITE_APIMART_RATE_LIMIT_COOLDOWN_MS=30000
VITE_APIMART_TASK_POLL_INTERVAL_MS=2500
VITE_APIMART_TASK_POLL_TIMEOUT_MS=120000

MUZHI_API_KEY=your_muzhi_api_key
MUZHI_BASE_URL=https://api.muzhi.ai
MUZHI_GENERATIONS_URL=https://api.muzhi.ai/v1/images/generations
MUZHI_EDITS_URL=https://api.muzhi.ai/v1/images/edits
VITE_MUZHI_BASE_URL=/api/muzhi
VITE_MUZHI_IMAGE_MODEL=gpt-image-2
VITE_MUZHI_TEXT_MODEL=gemini-2.5-pro
VITE_MUZHI_ENABLE_PROMPT_REWRITE=false
VITE_MUZHI_MIN_REQUEST_INTERVAL_MS=5000
VITE_MUZHI_MAX_RATE_LIMIT_RETRIES=4
VITE_MUZHI_RATE_LIMIT_COOLDOWN_MS=30000
VITE_MUZHI_TASK_POLL_INTERVAL_MS=2500
VITE_MUZHI_TASK_POLL_TIMEOUT_MS=120000
